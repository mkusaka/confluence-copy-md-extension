{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["chrome", "vite/client"],
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
