{
  "name": "confluence-copy-helper",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint src vite.config.ts",
    "test": "vitest run",
    "package": "rm -f chrome-extension.zip && pnpm build && cd dist && zip -r ../chrome-extension.zip ."
  },
  "dependencies": {
    "mdast-util-from-adf": "^2.1.1",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@atlaskit/adf-schema": "56.1.6",
    "@crxjs/vite-plugin": "2.7.1",
    "@types/chrome": "0.2.2",
    "@types/mdast": "4.0.4",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.15.1"
}
